# Root env file for docker compose. Copy to .env.staging / .env.production
# and run:  docker compose --env-file .env.production up -d --build
#
# Local defaults work without this file.

ENVIRONMENT=production

# Ports exposed on the host.
BACKEND_PORT=8000
FRONTEND_PORT=8080

# Origins the backend accepts (the public URL the frontend is served from).
CORS_ORIGINS=https://chat.example.com

# Public URL the browser uses to reach the backend (baked into the build).
FRONTEND_API_URL=https://api.example.com

# --- LLM (Anthropic Claude) --------------------------------------------------
# Required to answer real questions.
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-5
LLM_MAX_TOKENS=1024
CONTACT_FALLBACK=הממונה הישיר
# Optional outbound proxy for the Anthropic API (org networks only).
# LLM_PROXY_URL=http://10.106.1.5:80
LLM_VERIFY_SSL=true
LLM_TIMEOUT_SECONDS=60
