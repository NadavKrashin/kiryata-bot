# Copy to .env (local), .env.staging, or .env.production and adjust.

# Comma-separated list of origins allowed to call the API (CORS).
# Local dev (Vite): http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Free-form label for the running environment (local | staging | production).
ENVIRONMENT=local

# --- Add your LLM provider keys here when wiring get_answer() ---
# e.g. OPENAI_API_KEY=...
# e.g. ANTHROPIC_API_KEY=...
