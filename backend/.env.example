# Copy to .env (local), .env.staging, or .env.production and adjust.

# Comma-separated list of origins allowed to call the API (CORS).
# Local dev (Vite): http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Free-form label for the running environment (local | staging | production).
ENVIRONMENT=local

# --- LLM (Anthropic Claude) --------------------------------------------------
# Required to answer real questions.
ANTHROPIC_API_KEY=sk-ant-...

# Model id (swap to claude-haiku-4-5 for cheaper / faster answers).
LLM_MODEL=claude-sonnet-4-5

# Max tokens for the answer.
LLM_MAX_TOKENS=1024

# Who to contact when the answer isn't in the procedures (shown in the answer).
CONTACT_FALLBACK=הממונה הישיר

# Optional outbound HTTP proxy for the Anthropic API (org networks only).
# Leave empty to connect directly.
# LLM_PROXY_URL=http://10.106.1.5:80

# Verify TLS certificates on the Anthropic connection (set false only if an
# intercepting proxy forces it).
LLM_VERIFY_SSL=true

# Request timeout (seconds) for the Anthropic API call.
LLM_TIMEOUT_SECONDS=60

# Optional path overrides (default: backend/app/docs and backend/app/glossary.yaml)
# DOCS_DIR=
# GLOSSARY_PATH=
